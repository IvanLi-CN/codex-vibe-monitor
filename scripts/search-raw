#!/bin/sh

set -eu

usage() {
  echo "Usage: search-raw [--regex] [--root PATH] <needle>" >&2
}

mode="fixed"
root="${SEARCH_RAW_ROOT:-/srv/app/data/proxy_raw_payloads}"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --regex)
      mode="regex"
      shift
      ;;
    --root)
      [ "$#" -ge 2 ] || {
        usage
        exit 2
      }
      root="$2"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage
      exit 2
      ;;
    *)
      break
      ;;
  esac
done

[ "$#" -eq 1 ] || {
  usage
  exit 2
}

needle="$1"
[ -d "$root" ] || exit 1

grep_mode="-F"
[ "$mode" = "regex" ] && grep_mode="-E"

file_list="$(mktemp "${TMPDIR:-/tmp}/search-raw.files.XXXXXX")"
cleanup() {
  rm -f "$file_list"
}
trap cleanup EXIT INT TERM HUP

find "$root" -type f \( -name '*.bin' -o -name '*.bin.gz' \) -print | sort > "$file_list"

matched=1
while IFS= read -r path; do
  [ -n "$path" ] || continue
  case "$path" in
    *.bin)
      if grep -nH ${grep_mode} -- "$needle" "$path"; then
        matched=0
      fi
      ;;
    *.bin.gz)
      if gzip -cd -- "$path" \
        | grep -n ${grep_mode} -- "$needle" \
        | awk -v path="$path" '{ print path ":" $0 }'
      then
        matched=0
      fi
      ;;
  esac
done < "$file_list"

exit "$matched"
