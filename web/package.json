{
  "name": "web",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && bun scripts/write-version.mjs",
    "demo:dev": "VITE_APP_RUNTIME=demo vite",
    "demo:build": "VITE_APP_RUNTIME=demo VITE_BUILD_OUT_DIR=demo-dist tsc -b && VITE_APP_RUNTIME=demo VITE_BUILD_OUT_DIR=demo-dist vite build && VITE_BUILD_OUT_DIR=demo-dist bun scripts/write-version.mjs",
    "demo:preview": "VITE_APP_RUNTIME=demo VITE_BUILD_OUT_DIR=demo-dist vite preview",
    "build:pwa-test": "vite build && bun scripts/write-version.mjs",
    "lint": "bun --cwd .. run lint:web",
    "test": "vitest run --project=unit",
    "test-storybook": "vitest run --project=storybook",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:pwa": "playwright test -c playwright.pwa.config.ts",
    "pwa:test-server": "bun run build:pwa-test && bun tests/pwa/test-server.mjs",
    "storybook": "bun run scripts/run-storybook.mjs",
    "storybook:ci": "bun run scripts/run-storybook.mjs --ci",
    "storybook:build": "storybook build",
    "build-storybook": "bun run storybook:build"
  },
  "dependencies": {
    "@iconify-icons/mdi": "^1.2.48",
    "@iconify/react": "^6.0.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.4.4",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "react": "^19.1.1",
    "react-activity-calendar": "^2.7.15",
    "react-dom": "^19.1.1",
    "react-json-view-lite": "2.5.0",
    "react-router-dom": "^7.9.5",
    "recharts": "^3.3.0",
    "tailwind-merge": "^3.5.0",
    "workbox-core": "^7.3.0",
    "workbox-precaching": "^7.3.0",
    "workbox-routing": "^7.3.0",
    "workbox-strategies": "^7.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@storybook/addon-a11y": "^10.2.12",
    "@storybook/addon-docs": "^10.2.12",
    "@storybook/addon-vitest": "10.2.17",
    "@storybook/react-vite": "^10.2.12",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/browser": "4.1.0",
    "@vitest/browser-playwright": "4.1.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^28.1.0",
    "msw": "^2.15.0",
    "postcss": "^8.5.6",
    "storybook": "^10.2.12",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.9.3",
    "vite": "^7.1.7",
    "vite-plugin-pwa": "^1.1.0",
    "vitest": "4.1.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
